# ============================================================
# AI Provider Configuration
# ============================================================
# Cambiar de proveedor: solo modificar AI_PROVIDER y AI_API_KEY
# Proveedores soportados: "openai", "deepseek"
# ============================================================

AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key-here
AI_MODEL=gpt-4o-mini

# Para usar DeepSeek, descomentar las siguientes líneas:
# AI_PROVIDER=deepseek
# AI_API_KEY=sk-your-deepseek-key-here
# AI_MODEL=deepseek-chat

# ============================================================
# Server
# ============================================================
PORT=3001
NODE_ENV=development

# ============================================================
# Database (MongoDB)
# ============================================================
MONGODB_URI=mongodb://localhost:27017/learning-app
